# Ignore Python cache
__pycache__/
*.pyc

# Ignore backup files (we're backing up, not including backups in the repo)
*.tar.gz
*.manifest.json
*.log
backup.log

# Ignore temporary files
tmp/
temp/

# Ignore environment files (secrets) - DO NOT commit
.env
.env.*
.env.local
.env*.local
# .env.backup - temporarily tracked for testing, remove before final commit